{
  "firestore": {
    "database": "(default)",
    "location": "northamerica-south1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint"
      ]
    }
  ],
  "hosting": {
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/**",
        "headers": [
          { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
          { "key": "X-XSS-Protection", "value": "1; mode=block" }
        ]
      },
      {
        "source": "/**/*.@(js|css|png|jpg|jpeg|svg|webp|woff|woff2|ttf|eot|otf)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ],
    "redirects": [
      { "source": "/.git", "destination": "/", "type": 302 },
      { "source": "/.git/**", "destination": "/", "type": 302 },
      { "source": "/.DS_Store", "destination": "/", "type": 302 },
      { "source": "/wp-admin", "destination": "/", "type": 302 },
      { "source": "/wp-admin/**", "destination": "/", "type": 302 },
      { "source": "/wp-config.php.bak", "destination": "/", "type": 302 },
      { "source": "/phpmyadmin", "destination": "/", "type": 302 },
      { "source": "/phpmyadmin/**", "destination": "/", "type": 302 },
      { "source": "/phpinfo.php", "destination": "/", "type": 302 },
      { "source": "/backup.zip", "destination": "/", "type": 302 },
      { "source": "/backup.sql", "destination": "/", "type": 302 },
      { "source": "/database.sql", "destination": "/", "type": 302 },
      { "source": "/config.php", "destination": "/", "type": 302 }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "database": {
      "port": 9000
    },
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true
    },
    "singleProjectMode": true
  }
}
